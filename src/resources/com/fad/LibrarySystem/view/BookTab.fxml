<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.fad.LibrarySystem.controller.BookFXController">
   <children>
      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox spacing="10.0">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
               <children>
                  <TextField fx:id="genreSearchField" promptText="Search by genre..." />
                  <Button mnemonicParsing="false" onAction="#handleSearch" text="Search" />
                  <Separator orientation="VERTICAL" />
                  <Button mnemonicParsing="false" onAction="#handleAddBook" text="Add Book" />
                  <Button mnemonicParsing="false" onAction="#handleDeleteBook" text="Delete Book" />
               </children>
            </HBox>
            <TableView fx:id="bookTable" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colBookId"  prefWidth="80.0"  text="ID" />
                <TableColumn fx:id="colTitle"   prefWidth="200.0" text="Title" />
                <TableColumn fx:id="colAuthor"  prefWidth="150.0" text="Author" />
                <TableColumn fx:id="colGenre"   prefWidth="100.0" text="Genre" />
                <TableColumn fx:id="colStatus"  prefWidth="70.0"  text="Status" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
