<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.fad.LibrarySystem.controller.MemberFXController">
   <children>
      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox spacing="10.0">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
               <children>
                  <Button mnemonicParsing="false" onAction="#handleRegister" text="Register Member" />
                  <Button mnemonicParsing="false" onAction="#handleRemove"   text="Remove Member" />
               </children>
            </HBox>
            <TableView fx:id="memberTable" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colMemberID"    prefWidth="120.0" text="Member ID" />
                <TableColumn fx:id="colName"         prefWidth="200.0" text="Name" />
                <TableColumn fx:id="colBorrowCount"  prefWidth="120.0" text="Items Borrowed" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
